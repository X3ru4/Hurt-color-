{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.wolf.v2": {
      "arrays": {
        "textures": {
          "Array.default": [
            "Texture.pale_default",
            "Texture.ashen_default",
            "Texture.black_default",
            "Texture.chestnut_default",
            "Texture.rusty_default",
            "Texture.snowy_default",
            "Texture.spotted_default",
            "Texture.striped_default",
            "Texture.woods_default"
          ],
          "Array.baby_default": [
            "Texture.baby_pale_default",
            "Texture.baby_ashen_default",
            "Texture.baby_black_default",
            "Texture.baby_chestnut_default",
            "Texture.baby_rusty_default",
            "Texture.baby_snowy_default",
            "Texture.baby_spotted_default",
            "Texture.baby_striped_default",
            "Texture.baby_woods_default"
          ],
          "Array.angry": [
            "Texture.pale_angry",
            "Texture.ashen_angry",
            "Texture.black_angry",
            "Texture.chestnut_angry",
            "Texture.rusty_angry",
            "Texture.snowy_angry",
            "Texture.spotted_angry",
            "Texture.striped_angry",
            "Texture.woods_angry"
          ],
          "Array.baby_angry": [
            "Texture.baby_pale_angry",
            "Texture.baby_ashen_angry",
            "Texture.baby_black_angry",
            "Texture.baby_chestnut_angry",
            "Texture.baby_rusty_angry",
            "Texture.baby_snowy_angry",
            "Texture.baby_spotted_angry",
            "Texture.baby_striped_angry",
            "Texture.baby_woods_angry"
          ],
          "Array.tame": [
            "Texture.pale_tame",
            "Texture.ashen_tame",
            "Texture.black_tame",
            "Texture.chestnut_tame",
            "Texture.rusty_tame",
            "Texture.snowy_tame",
            "Texture.spotted_tame",
            "Texture.striped_tame",
            "Texture.woods_tame"
          ],
          "Array.baby_tame": [
            "Texture.baby_pale_tame",
            "Texture.baby_ashen_tame",
            "Texture.baby_black_tame",
            "Texture.baby_chestnut_tame",
            "Texture.baby_rusty_tame",
            "Texture.baby_snowy_tame",
            "Texture.baby_spotted_tame",
            "Texture.baby_striped_tame",
            "Texture.baby_woods_tame"
          ]
        }
      },
      "geometry": "query.is_baby ? Geometry.baby : Geometry.default",
      "materials": [ { "*": "Material.default" } ],
      "textures": [ "query.is_baby ? (query.is_angry ? Array.baby_angry[query.variant] : (query.is_tamed ? Array.baby_tame[query.variant] : Array.baby_default[query.variant])) :  query.is_angry ? Array.angry[query.variant] : (query.is_tamed ? Array.tame[query.variant] : Array.default[query.variant])" ],
      "overlay_color": {
        "a": "(q.is_alive) ? { v.hurt_stop = false; v.is_hurt = v.is_hurt ?? false;; v.hurt_time = v.hurt_time ?? 0.0; v.hurt_time = !v.is_hurt ? q.life_time; v.is_hurt = false; v.fade_in = q.is_pack_setting_enabled('hcp:fade_in'); v.fade_out = q.is_pack_setting_enabled('hcp:fade_out'); }; return this;"
      },
      "is_hurt_color": {
        "r": "q.get_pack_setting('hcp:mob_red') / 255",
        "g": "q.get_pack_setting('hcp:mob_green') / 255",
        "b": "q.get_pack_setting('hcp:mob_blue') / 255",
        "a": "(!v.hurt_stop) ? { (q.life_time - v.hurt_time >= 0.5) ? { v.hurt_time = q.life_time; v.hurt_stop = !q.is_alive ? true }; v.is_hurt = true; v.hcp_alpha = q.get_pack_setting('hcp:mob_alpha') / 255; v.hurt_progress = math.clamp((v.fade_in || v.fade_out ? (v.fade_in && v.fade_out ? (math.sin(((q.life_time - v.hurt_time) / 0.5) * 180)) : (v.fade_in ? ((q.life_time - v.hurt_time) / 0.5) : (1 - ((q.life_time - v.hurt_time) / 0.5)))) : 1), 0, 1); return v.hurt_stop ? 0 : math.ease_out_cubic(0.0, v.hcp_alpha, v.hurt_progress); } : this;"
      },
      "on_fire_color": {
        "r": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_red') / 255) : this",
        "g": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_green') / 255) : this",
        "b": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_blue') / 255) : this",
        "a": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_alpha') / 255) : this"
      }
    }
  }
}
