{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.villager_v3_base": {
      "arrays": {
        "textures": {
          "Array.skins": [
            "Texture.base",
            "Texture.base2",
            "Texture.base3",
            "Texture.base4",
            "Texture.base5",
            "Texture.base6"
          ],
          "Array.baby_skins": [
            "Texture.baby_base",
            "Texture.baby_base2",
            "Texture.baby_base3",
            "Texture.baby_base4",
            "Texture.baby_base5",
            "Texture.baby_base6"
          ]
        }
      },
      "geometry": "query.is_baby ? Geometry.baby : Geometry.default",
      "materials": [
        { "*": "Material.default" }
      ],
      "textures": [
        "query.is_baby ? Array.baby_skins[query.skin_id] : Array.skins[query.skin_id]"
      ],
      "overlay_color": {
        "a": "(q.is_alive) ? { v.hurt_stop = false; v.is_hurt = v.is_hurt ?? false;; v.hurt_time = v.hurt_time ?? 0.0; v.hurt_time = !v.is_hurt ? q.life_time; v.is_hurt = false; v.fade_in = q.is_pack_setting_enabled('hcp:fade_in'); v.fade_out = q.is_pack_setting_enabled('hcp:fade_out'); }; return this;"
      },
      "is_hurt_color": {
        "r": "q.get_pack_setting('hcp:mob_red') / 255",
        "g": "q.get_pack_setting('hcp:mob_green') / 255",
        "b": "q.get_pack_setting('hcp:mob_blue') / 255",
        "a": "(!v.hurt_stop) ? { (q.life_time - v.hurt_time >= 0.5) ? { v.hurt_time = q.life_time; v.hurt_stop = !q.is_alive ? true }; v.is_hurt = true; v.hcp_alpha = q.get_pack_setting('hcp:mob_alpha') / 255; v.hurt_progress = math.clamp((v.fade_in || v.fade_out ? (v.fade_in && v.fade_out ? (math.sin(((q.life_time - v.hurt_time) / 0.5) * 180)) : (v.fade_in ? ((q.life_time - v.hurt_time) / 0.5) : (1 - ((q.life_time - v.hurt_time) / 0.5)))) : 1), 0, 1); return v.hurt_stop ? 0 : math.ease_out_cubic(0.0, v.hcp_alpha, v.hurt_progress); } : this;"
      },
      "on_fire_color": {
        "r": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_red') / 255) : this",
        "g": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_green') / 255) : this",
        "b": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_blue') / 255) : this",
        "a": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_alpha') / 255) : this"
      }
    },
    "controller.render.villager_v3_masked": {
      "arrays": {
        "textures": {
          "Array.biomes": [
            "Texture.plains",
            "Texture.desert",
            "Texture.jungle",
            "Texture.savanna",
            "Texture.snow",
            "Texture.swamp",
            "Texture.taiga"
          ],
          "Array.baby_biomes": [
            "Texture.baby_plains",
            "Texture.baby_desert",
            "Texture.baby_jungle",
            "Texture.baby_savanna",
            "Texture.baby_snow",
            "Texture.baby_swamp",
            "Texture.baby_taiga"
          ],
          "Array.professions": [
            "Texture.unskilled",
            "Texture.farmer",
            "Texture.fisherman",
            "Texture.shepherd",
            "Texture.fletcher",
            "Texture.librarian",
            "Texture.cartographer",
            "Texture.cleric",
            "Texture.armorer",
            "Texture.weapon_smith",
            "Texture.tool_smith",
            "Texture.butcher",
            "Texture.leatherworker",
            "Texture.stonemason",
            "Texture.nitwit"
          ]
        }
      },
      "geometry": "query.is_baby ? Geometry.baby : Geometry.default",
      "materials": [
        { "*": "(query.is_baby || variable.profession_index == 0) ? Material.default : Material.masked" }
      ],
      "textures": [
        "query.is_baby ? Array.baby_biomes[query.mark_variant] : Array.biomes[query.mark_variant]",
        "Array.professions[variable.profession_index]"
      ],
      "overlay_color": {
        "a": "(q.is_alive) ? { v.hurt_stop = false; v.is_hurt = v.is_hurt ?? false;; v.hurt_time = v.hurt_time ?? 0.0; v.hurt_time = !v.is_hurt ? q.life_time; v.is_hurt = false; v.fade_in = q.is_pack_setting_enabled('hcp:fade_in'); v.fade_out = q.is_pack_setting_enabled('hcp:fade_out'); }; return this;"
      },
      "is_hurt_color": {
        "r": "q.get_pack_setting('hcp:mob_red') / 255",
        "g": "q.get_pack_setting('hcp:mob_green') / 255",
        "b": "q.get_pack_setting('hcp:mob_blue') / 255",
        "a": "(!v.hurt_stop) ? { (q.life_time - v.hurt_time >= 0.5) ? { v.hurt_time = q.life_time; v.hurt_stop = !q.is_alive ? true }; v.is_hurt = true; v.hcp_alpha = q.get_pack_setting('hcp:mob_alpha') / 255; v.hurt_progress = math.clamp((v.fade_in || v.fade_out ? (v.fade_in && v.fade_out ? (math.sin(((q.life_time - v.hurt_time) / 0.5) * 180)) : (v.fade_in ? ((q.life_time - v.hurt_time) / 0.5) : (1 - ((q.life_time - v.hurt_time) / 0.5)))) : 1), 0, 1); return v.hurt_stop ? 0 : math.ease_out_cubic(0.0, v.hcp_alpha, v.hurt_progress); } : this;"
      },
      "on_fire_color": {
        "r": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_red') / 255) : this",
        "g": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_green') / 255) : this",
        "b": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_blue') / 255) : this",
        "a": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_alpha') / 255) : this"
      }
    },
    "controller.render.villager_v3_level": {
      "arrays": {
        "textures": {
          "Array.levels": [
            "Texture.level_stone",
            "Texture.level_iron",
            "Texture.level_gold",
            "Texture.level_emerald",
            "Texture.level_diamond"
          ]
        }
      },
      "rebuild_animation_matrices": true,
      "geometry": "Geometry.default",
      // If we are not babies, unskilled, or nitwits we can have a job level
      "part_visibility": [ { "*": "!query.is_baby && variable.profession_index != 0 && variable.profession_index != 14" } ],
      "materials": [
        { "*": "Material.default" }
      ],
      "textures": [
        "Array.levels[variable.level_index]"
      ]
    }
  }
}
