{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.cat.v2": {
      "arrays": {
        "textures": {
          "Array.skins": [
            "Texture.white",
            "Texture.black",
            "Texture.red",
            "Texture.siamese",
            "Texture.british",
            "Texture.calico",
            "Texture.persian",
            "Texture.ragdoll",
            "Texture.tabby",
            "Texture.all_black",
            "Texture.jellie"
          ],
          "Array.baby_skins": [
            "Texture.baby_white",
            "Texture.baby_black",
            "Texture.baby_red",
            "Texture.baby_siamese",
            "Texture.baby_british",
            "Texture.baby_calico",
            "Texture.baby_persian",
            "Texture.baby_ragdoll",
            "Texture.baby_tabby",
            "Texture.baby_all_black",
            "Texture.baby_jellie"
          ],
          "Array.tame": [
            "Texture.white_tame",
            "Texture.black_tame",
            "Texture.red_tame",
            "Texture.siamese_tame",
            "Texture.british_tame",
            "Texture.calico_tame",
            "Texture.persian_tame",
            "Texture.ragdoll_tame",
            "Texture.tabby_tame",
            "Texture.all_black_tame",
            "Texture.jellie_tame"
          ],
          "Array.baby_tame": [
            "Texture.baby_white_tame",
            "Texture.baby_black_tame",
            "Texture.baby_red_tame",
            "Texture.baby_siamese_tame",
            "Texture.baby_british_tame",
            "Texture.baby_calico_tame",
            "Texture.baby_persian_tame",
            "Texture.baby_ragdoll_tame",
            "Texture.baby_tabby_tame",
            "Texture.baby_all_black_tame",
            "Texture.baby_jellie_tame"
          ]
        }
      },
      "geometry": "query.is_baby ? Geometry.baby : Geometry.default",
      "materials": [{ "*": "Material.default" }],
      "textures": [
        "query.is_tamed ?  query.is_baby ? Array.baby_tame[query.variant] : Array.tame[query.variant] : query.is_baby ? Array.baby_skins[query.variant] : Array.skins[query.variant]"
      ],
      "overlay_color": {
        "a": "(q.is_alive) ? { v.hurt_stop = false; v.is_hurt = v.is_hurt ?? false;; v.hurt_time = v.hurt_time ?? 0.0; v.hurt_time = !v.is_hurt ? q.life_time; v.is_hurt = false; v.fade_in = q.is_pack_setting_enabled('hcp:fade_in'); v.fade_out = q.is_pack_setting_enabled('hcp:fade_out'); }; return this;"
      },
      "is_hurt_color": {
        "r": "q.get_pack_setting('hcp:mob_red') / 255",
        "g": "q.get_pack_setting('hcp:mob_green') / 255",
        "b": "q.get_pack_setting('hcp:mob_blue') / 255",
        "a": "(!v.hurt_stop) ? { (q.life_time - v.hurt_time >= 0.5) ? { v.hurt_time = q.life_time; v.hurt_stop = !q.is_alive ? true }; v.is_hurt = true; v.hcp_alpha = q.get_pack_setting('hcp:mob_alpha') / 255; v.hurt_progress = math.clamp((v.fade_in || v.fade_out ? (v.fade_in && v.fade_out ? (math.sin(((q.life_time - v.hurt_time) / 0.5) * 180)) : (v.fade_in ? ((q.life_time - v.hurt_time) / 0.5) : (1 - ((q.life_time - v.hurt_time) / 0.5)))) : 1), 0, 1); return v.hurt_stop ? 0 : math.ease_out_cubic(0.0, v.hcp_alpha, v.hurt_progress); } : this;"
      },
      "on_fire_color": {
        "r": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_red') / 255) : this",
        "g": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_green') / 255) : this",
        "b": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_blue') / 255) : this",
        "a": "q.is_pack_setting_enabled('hcp:on_fire_color') ? (q.get_pack_setting('hcp:mob_alpha') / 255) : this"
      }
    }
  }
}
